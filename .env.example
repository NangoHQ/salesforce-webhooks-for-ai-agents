# --- Nango (dashboard: https://app.nango.dev) ---

# Environment Settings > API secret key (use your dev environment key)
NANGO_SECRET_KEY=

# Environment Settings > Webhooks > Signing key.
# Used to verify webhooks Nango sends to this app. Distinct from the secret key!
NANGO_WEBHOOK_SIGNING_KEY=

# The integration ID (unique key) of your Salesforce integration, e.g. "salesforce"
NANGO_INTEGRATION_ID=salesforce

# Optional shortcut: a pre-existing Salesforce connection ID (Connections tab).
# Leave empty to use the real flow — the app's "Connect Salesforce" button
# authorizes an account via Nango Connect and provisions the org automatically.
NANGO_CONNECTION_ID=

# Nango's inbound webhook URL for your Salesforce integration.
# Copy it from: Integrations > [your Salesforce integration] > Webhook URL.
# Looks like: https://api.nango.dev/webhook/<environment-uuid>/salesforce
NANGO_INBOUND_WEBHOOK_URL=

# --- Anthropic (agent) ---
ANTHROPIC_API_KEY=

# Optional: Claude model for the agent (default: claude-sonnet-5)
# AGENT_MODEL=

# --- App ---
PORT=3000
